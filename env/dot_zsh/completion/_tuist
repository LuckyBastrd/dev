#compdef tuist

__tuist_complete() {
    local -ar non_empty_completions=("${@:#(|:*)}")
    local -ar empty_completions=("${(M)@:#(|:*)}")
    _describe -V '' non_empty_completions -- empty_completions -P $'\'\''
}

__tuist_custom_complete() {
    local -a completions
    completions=("${(@f)"$("${command_name}" "${@}" "${command_line[@]}")"}")
    if [[ "${#completions[@]}" -gt 1 ]]; then
        __tuist_complete "${completions[@]:0:-1}"
    fi
}

__tuist_cursor_index_in_current_word() {
    if [[ -z "${QIPREFIX}${IPREFIX}${PREFIX}" ]]; then
        printf 0
    else
        printf %s "${#${(z)LBUFFER}[-1]}"
    fi
}

_tuist() {
    emulate -RL zsh -G
    setopt extendedglob nullglob numericglobsort
    unsetopt aliases banghist

    local -xr SAP_SHELL=zsh
    local -x SAP_SHELL_VERSION
    SAP_SHELL_VERSION="$(builtin emulate zsh -c 'printf %s "${ZSH_VERSION}"')"
    local -r SAP_SHELL_VERSION

    local context state state_descr line
    local -A opt_args

    local -r command_name="${words[1]}"
    local -ar command_line=("${words[@]}")
    local -ir current_word_index="$((CURRENT - 1))"

    local -i ret=1
    local -ar arg_specs=(
        '(-h --help)'{-h,--help}'[Show help information.]'
        '(-): :->command'
        '(-)*:: :->arg'
    )
    _arguments -w -s -S : "${arg_specs[@]}" && ret=0
    case "${state}" in
    command)
        local -ar subcommands=(
            'init:Get started with Tuist in your Xcode project or create a generated project.'
            'hash:Utilities to debug the hashing logic used by features like binary caching or selective testing.'
            'build:A set of commands to manage your project builds.'
            'cache:A set of commands related to caching.'
            'clean:Clean all the artifacts stored locally'
            'dump:Outputs the manifest as a JSON'
            'edit:Generates a temporary project to edit the project in the current directory'
            'generate:Generate a project or inspect generation runs.'
            'graph:Generates a graph from the workspace or project in the current directory'
            'install:Installs any remote content (e.g. dependencies) necessary to interact with the project.'
            'migration:A set of utilities to assist in the migration of Xcode projects to Tuist.'
            'plugin:A set of commands for plugin'\''s management.'
            'registry:A set of commands to interact with the Tuist Registry.'
            'run:Runs a scheme or target in the project'
            'scaffold:Generates new project based on a template'
            'setup:Commands to set up and configure Tuist services'
            'test:Tests a project'
            'inspect:Inspect your project to identify issues such as implicit or redundant dependencies.'
            'xcodebuild:tuist xcodebuild extends the xcodebuild CLI with server capabilities such as selective testing or analytics.'
            'share:Generate a link to share your app.'
            'mcp:Commands for interfacing with Tuist'\''s MCP server'
            'account:A set of commands to manage your Tuist account'
            'project:A set of commands to manage your Tuist projects.'
            'bundle:A set of commands to manage your project bundles.'
            'organization:A set of commands to manage your Tuist organizations.'
            'auth:Manage authentication'
            'version:Outputs the current version of tuist'
            'help:Show subcommand help information.'
        )
        _describe -V subcommand subcommands
        ;;
    arg)
        case "${words[1]}" in
        init|hash|build|cache|clean|dump|edit|generate|graph|install|migration|plugin|registry|run|scaffold|setup|test|inspect|xcodebuild|share|mcp|account|project|bundle|organization|auth|version|help)
            "_tuist_${words[1]}"
            ;;
        esac
        ;;
    esac

    return "${ret}"
}

