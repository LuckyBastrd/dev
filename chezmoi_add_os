#!/usr/bin/env bash

# Check if a file argument is given
if [ -z "$1" ]; then
  echo "Usage: $0 <file-to-add>"
  exit 1
fi

file="$1"

# Get OS from chezmoi data command, requires jq
os=$(chezmoi data --json | jq -r '.chezmoi.os')

if [ -z "$os" ]; then
  echo "Failed to get OS from chezmoi"
  exit 1
fi

# Run chezmoi add
chezmoi add "$file"

# Extract base filename (e.g. '.zshrc' or 'config')
base=$(basename "$file")

# Determine chezmoi source dir (default or config override)
source_dir=$(chezmoi source-path)

# If source_dir is a file, take its parent directory
if [ -f "$source_dir" ]; then
  source_dir=$(dirname "$source_dir")
fi

# Build the old and new filenames (assuming dotfile with 'dot_' prefix)
old_file="${source_dir}/dot_${base}"
new_file="${old_file}.${os}"

# Rename the file to include the OS suffix
if [ -f "$old_file" ]; then
  mv "$old_file" "$new_file"
  echo "Renamed $old_file to $new_file"
else
  echo "Expected file $old_file not found"
  exit 1
fi

